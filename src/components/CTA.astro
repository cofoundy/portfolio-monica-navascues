---
import { siteConfig } from "../config";
---

<section id="contact" class="py-20 md:py-24 relative overflow-hidden" style={`background-color: var(--color-accent);`}>
  <!-- Subtle pattern overlay -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-0 right-0 w-64 h-64 rounded-full" style="background: radial-gradient(circle, white 0%, transparent 70%); transform: translate(30%, -30%);"></div>
    <div class="absolute bottom-0 left-0 w-48 h-48 rounded-full" style="background: radial-gradient(circle, white 0%, transparent 70%); transform: translate(-30%, 30%);"></div>
  </div>

  <div class="relative max-w-3xl mx-auto px-6 text-center">

    <div class="reveal">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        {siteConfig.cta.title}
      </h2>

      <p class="text-lg text-white/85 mb-10 max-w-xl mx-auto leading-relaxed">
        {siteConfig.cta.description}
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`mailto:${siteConfig.social.email}?subject=${encodeURIComponent(siteConfig.cta.emailSubject)}`}
          class="inline-flex items-center gap-2 px-8 py-4 rounded-full font-bold text-base transition-all hover:scale-105 hover:shadow-lg"
          style={`background-color: white; color: var(--color-primary-dark);`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          {siteConfig.cta.primaryButton}
        </a>

        <a
          href={`mailto:${siteConfig.social.email}?subject=${encodeURIComponent(siteConfig.cta.emailSubject)}`}
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full font-semibold text-base border-2 border-white/40 text-white transition-all hover:bg-white/10 hover:border-white/60"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          {siteConfig.cta.secondaryButton}
        </a>
      </div>
    </div>

  </div>
</section>
