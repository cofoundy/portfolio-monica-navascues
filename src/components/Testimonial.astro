---
import { siteConfig } from "../config";
---

<section id="testimonial" class="py-16 md:py-20" style={`background-color: var(--color-surface);`}>
  <div class="max-w-3xl mx-auto px-6">

    <div class="reveal text-center">
      <!-- Quote icon -->
      <div class="mb-6">
        <svg class="w-10 h-10 mx-auto opacity-30" style="color: var(--color-accent);" fill="currentColor" viewBox="0 0 24 24">
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/>
        </svg>
      </div>

      <blockquote class="testimonial-glow rounded-2xl p-8 bg-white border border-emerald-100/50">
        <p class="text-lg md:text-xl leading-relaxed italic" style="color: #334155;">
          "{siteConfig.testimonial.text}"
        </p>
        <footer class="mt-6">
          <p class="text-sm font-semibold" style="color: var(--color-primary-dark);">
            — {siteConfig.testimonial.author}
          </p>
          <p class="text-xs mt-0.5" style="color: var(--color-primary);">
            {siteConfig.testimonial.role}
          </p>
        </footer>
      </blockquote>
    </div>

  </div>
</section>
