---
import { siteConfig } from "../config";

const serviceIcons: Record<string, string> = {
  discover: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>`,
  lead: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
  transform: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>`,
};
---

<section id="services" class="py-20 md:py-24" style={`background-color: var(--color-surface);`}>
  <div class="max-w-6xl mx-auto px-6">

    <!-- Language toggle -->
    <div class="flex justify-center mb-10">
      <div class="inline-flex rounded-full p-1 border" style="border-color: rgba(2, 132, 199, 0.2); background: white;">
        <button
          id="btn-en"
          class="lang-toggle px-5 py-2 rounded-full text-sm font-semibold transition-all"
          style="background-color: var(--color-primary); color: white;"
          data-lang="en"
        >
          English
        </button>
        <button
          id="btn-es"
          class="lang-toggle px-5 py-2 rounded-full text-sm font-semibold transition-all"
          style="background: transparent; color: var(--color-primary);"
          data-lang="es"
        >
          Español
        </button>
      </div>
    </div>

    <!-- ========== ENGLISH SERVICES ========== -->
    <div id="services-en">
      <div class="reveal text-center mb-14">
        <h2 class="text-sm font-bold uppercase tracking-widest mb-3" style="color: var(--color-primary);">
          Who I Help
        </h2>
        <p class="text-xl md:text-2xl font-medium max-w-2xl mx-auto" style="color: var(--color-primary-dark);">
          Three pathways to growth — each one tailored to where you are today.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mb-10">
        {siteConfig.services.map((service, i) => (
          <div
            class={`reveal stagger-${i + 1} pathway-card bg-white rounded-2xl p-7 border-2 border-transparent`}
            style="border-color: rgba(2, 132, 199, 0.1);"
          >
            <div class="flex items-center gap-3 mb-5">
              <div
                class="w-14 h-14 rounded-xl flex items-center justify-center"
                style={`background-color: rgba(16, 185, 129, 0.1); color: var(--color-accent);`}
                set:html={serviceIcons[service.id]}
              />
              <div>
                <span class="text-2xl font-bold" style="color: var(--color-accent);">{service.verb}</span>
              </div>
            </div>

            <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary-dark);">
              {service.title}
            </h3>

            <p class="font-accent italic text-base mb-4" style="color: var(--color-primary);">
              {service.tagline}
            </p>

            <p class="text-sm leading-relaxed mb-5" style="color: #64748b;">
              {service.description}
            </p>

            <ul class="space-y-2">
              {service.areas.map((area) => (
                <li class="flex items-start gap-2 text-sm" style="color: #475569;">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: var(--color-accent);"></span>
                  {area}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="reveal stagger-4">
        <div
          class="bg-white rounded-2xl p-7 md:p-8 border-2 pathway-card"
          style="border-color: rgba(12, 74, 110, 0.1);"
        >
          <div class="flex flex-col md:flex-row md:items-center gap-6">
            <div class="flex-shrink-0">
              <div
                class="w-14 h-14 rounded-xl flex items-center justify-center"
                style={`background-color: rgba(12, 74, 110, 0.08); color: var(--color-primary-dark);`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              </div>
            </div>
            <div class="flex-1">
              <h3 class="text-lg font-bold mb-1" style="color: var(--color-primary-dark);">
                {siteConfig.consulting.title}
              </h3>
              <p class="text-sm mb-3" style="color: var(--color-primary);">
                {siteConfig.consulting.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {siteConfig.consulting.areas.map((area) => (
                  <span
                    class="inline-block px-3 py-1 rounded-full text-xs font-medium"
                    style="background-color: var(--color-surface); color: var(--color-primary-dark);"
                  >
                    {area}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ========== SPANISH SERVICES ========== -->
    <div id="services-es" class="hidden">
      <div class="text-center mb-14">
        <h2 class="text-sm font-bold uppercase tracking-widest mb-3" style="color: var(--color-primary);">
          A Quién Ayudo
        </h2>
        <p class="text-xl md:text-2xl font-medium max-w-2xl mx-auto" style="color: var(--color-primary-dark);">
          Tres caminos hacia el crecimiento — cada uno adaptado a donde estás hoy.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mb-10">
        {siteConfig.servicesEs.map((service, i) => (
          <div
            class={`pathway-card bg-white rounded-2xl p-7 border-2 border-transparent`}
            style="border-color: rgba(2, 132, 199, 0.1);"
          >
            <div class="flex items-center gap-3 mb-5">
              <div
                class="w-14 h-14 rounded-xl flex items-center justify-center"
                style={`background-color: rgba(16, 185, 129, 0.1); color: var(--color-accent);`}
                set:html={serviceIcons[service.id]}
              />
              <div>
                <span class="text-2xl font-bold" style="color: var(--color-accent);">{service.verb}</span>
              </div>
            </div>

            <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary-dark);">
              {service.title}
            </h3>

            <p class="font-accent italic text-base mb-4" style="color: var(--color-primary);">
              {service.tagline}
            </p>

            <p class="text-sm leading-relaxed mb-5" style="color: #64748b;">
              {service.description}
            </p>

            <ul class="space-y-2">
              {service.areas.map((area) => (
                <li class="flex items-start gap-2 text-sm" style="color: #475569;">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: var(--color-accent);"></span>
                  {area}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div>
        <div
          class="bg-white rounded-2xl p-7 md:p-8 border-2 pathway-card"
          style="border-color: rgba(12, 74, 110, 0.1);"
        >
          <div class="flex flex-col md:flex-row md:items-center gap-6">
            <div class="flex-shrink-0">
              <div
                class="w-14 h-14 rounded-xl flex items-center justify-center"
                style={`background-color: rgba(12, 74, 110, 0.08); color: var(--color-primary-dark);`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              </div>
            </div>
            <div class="flex-1">
              <h3 class="text-lg font-bold mb-1" style="color: var(--color-primary-dark);">
                {siteConfig.consultingEs.title}
              </h3>
              <p class="text-sm mb-3" style="color: var(--color-primary);">
                {siteConfig.consultingEs.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {siteConfig.consultingEs.areas.map((area) => (
                  <span
                    class="inline-block px-3 py-1 rounded-full text-xs font-medium"
                    style="background-color: var(--color-surface); color: var(--color-primary-dark);"
                  >
                    {area}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  const btnEn = document.getElementById('btn-en');
  const btnEs = document.getElementById('btn-es');
  const servicesEn = document.getElementById('services-en');
  const servicesEs = document.getElementById('services-es');

  function switchLang(lang: string) {
    if (lang === 'es') {
      servicesEn?.classList.add('hidden');
      servicesEs?.classList.remove('hidden');
      btnEs!.style.backgroundColor = 'var(--color-primary)';
      btnEs!.style.color = 'white';
      btnEn!.style.backgroundColor = 'transparent';
      btnEn!.style.color = 'var(--color-primary)';
    } else {
      servicesEs?.classList.add('hidden');
      servicesEn?.classList.remove('hidden');
      btnEn!.style.backgroundColor = 'var(--color-primary)';
      btnEn!.style.color = 'white';
      btnEs!.style.backgroundColor = 'transparent';
      btnEs!.style.color = 'var(--color-primary)';
    }
  }

  btnEn?.addEventListener('click', () => switchLang('en'));
  btnEs?.addEventListener('click', () => switchLang('es'));
</script>
