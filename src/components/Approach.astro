---
import { siteConfig } from "../config";

const stepIcons = [
  `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>`,
];
---

<section id="approach" class="py-20 md:py-24" style={`background-color: var(--color-primary-dark);`}>
  <div class="max-w-5xl mx-auto px-6">

    <div class="reveal text-center mb-6">
      <h2 class="text-sm font-bold uppercase tracking-widest mb-3" style="color: var(--color-accent);">
        My Approach
      </h2>
    </div>

    <!-- Philosophy quote -->
    <div class="reveal stagger-1 text-center mb-16 max-w-3xl mx-auto">
      <p class="font-accent text-xl md:text-2xl italic leading-relaxed text-white/90">
        "Coaching isn't about fixing people — it's about creating space for discovery, growth, and confidence to move forward with intention."
      </p>
    </div>

    <!-- 4 steps -->
    <div class="relative">
      <!-- Connector line (desktop) -->
      <div class="hidden md:block absolute top-12 left-[12.5%] right-[12.5%] h-px bg-white/10">
        <div class="connector-line reveal h-full" style="background-color: var(--color-accent); opacity: 0.4;"></div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {siteConfig.approachSteps.map((step, i) => (
          <div class={`reveal stagger-${i + 1} text-center approach-step`}>
            <div
              class="w-16 h-16 md:w-20 md:h-20 rounded-full flex items-center justify-center mx-auto mb-4 border-2"
              style="border-color: var(--color-accent); background-color: rgba(16, 185, 129, 0.1); color: var(--color-accent);"
              set:html={stepIcons[i]}
            />
            <h3 class="text-lg font-bold text-white mb-1">{step.label}</h3>
            <p class="text-sm text-white/60">{step.description}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
