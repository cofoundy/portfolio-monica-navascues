---
import { siteConfig } from "../config";
---

<section id="hero" class="relative overflow-hidden" style={`background-color: var(--color-surface-light);`}>
  <!-- Subtle gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-br from-sky-50/50 via-transparent to-emerald-50/30 pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-6 py-20 md:py-28">
    <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">

      <!-- Photo with emerald ring -->
      <div class="hero-photo flex-shrink-0">
        <div class="relative">
          <div
            class="w-52 h-52 md:w-64 md:h-64 rounded-full p-1.5"
            style="background: linear-gradient(135deg, var(--color-primary), var(--color-accent));"
          >
            <img
              src="/profile.jpg"
              alt={siteConfig.name}
              class="w-full h-full rounded-full object-cover object-top"
              loading="eager"
            />
          </div>
          <!-- Decorative dot -->
          <div
            class="absolute -bottom-1 -right-1 w-6 h-6 rounded-full border-4 border-white"
            style="background-color: var(--color-accent);"
          ></div>
        </div>
      </div>

      <!-- Content -->
      <div class="text-center md:text-left flex-1">
        <p class="hero-brand text-sm font-semibold uppercase tracking-widest mb-2" style="color: var(--color-accent);">
          {siteConfig.brand}
        </p>

        <h1 class="hero-title text-4xl md:text-5xl lg:text-6xl font-bold leading-tight" style="color: var(--color-primary-dark);">
          {siteConfig.name}
        </h1>

        <p class="hero-subtitle text-lg md:text-xl mt-3" style="color: var(--color-primary);">
          {siteConfig.title}
        </p>

        <p class="hero-tagline font-accent text-xl md:text-2xl italic mt-5" style="color: var(--color-primary-dark);">
          "{siteConfig.tagline}"
        </p>

        <!-- Credential badges -->
        <div class="hero-credentials flex flex-wrap justify-center md:justify-start gap-2 mt-6">
          {siteConfig.credentials.map((cred) => (
            <span
              class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider border"
              style={`color: var(--color-primary-dark); border-color: var(--color-primary); background-color: rgba(2, 132, 199, 0.08);`}
              title={cred.title}
            >
              {cred.label}
            </span>
          ))}
        </div>

        <!-- CTA -->
        <div class="hero-cta mt-8 flex flex-col sm:flex-row items-center gap-4 justify-center md:justify-start">
          <a
            href={`mailto:${siteConfig.social.email}?subject=${encodeURIComponent(siteConfig.cta.emailSubject)}`}
            class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full text-white font-semibold text-base btn-hover"
            style="background-color: var(--color-accent);"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            {siteConfig.cta.primaryButton}
          </a>
          <a
            href={siteConfig.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-full font-medium border-2 transition-colors"
            style={`color: var(--color-primary-dark); border-color: var(--color-primary-dark);`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="hero-stats mt-14">
      <div class="bar-shimmer h-0.5 rounded-full mb-8"></div>
      <div class="flex justify-center gap-12 md:gap-20">
        {siteConfig.stats.map((stat) => (
          <div class="text-center">
            <div class="text-2xl md:text-3xl font-bold" style="color: var(--color-accent);">
              {stat.value}
            </div>
            <div class="text-sm mt-1" style="color: var(--color-primary);">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
